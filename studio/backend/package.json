{
  "name": "devforge-studio-backend",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "npx prisma db push --accept-data-loss && node dist/index.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "NODE_OPTIONS='--experimental-vm-modules' npx jest tests/api.test.ts --testTimeout=30000",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:responsive": "playwright test responsive",
    "test:forms": "playwright test forms",
    "test:buttons": "playwright test buttons",
    "test:auth": "playwright test auth",
    "test:a11y": "playwright test accessibility",
    "test:security": "playwright test security",
    "test:kanban": "playwright test ui-kanban",
    "test:integration": "playwright test integration",
    "test:report": "playwright show-report",
    "test:all": "npm run test:api && npm run test:e2e && echo '\n✅ Todos os testes passaram!'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.1.0",
    "@types/archiver": "^7.0.0",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "better-auth": "^1.1.0",
    "cloudflare": "^3.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ollama": "^0.6.3",
    "resend": "^4.0.1",
    "stripe": "^17.5.0",
    "validator": "^13.15.26",
    "ws": "^8.19.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "axe-core": "^4.10.2",
    "jest": "^30.2.0",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
