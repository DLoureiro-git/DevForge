# DevForge V2 — Environment Variables

# Database
DATABASE_URL="file:./dev.db"

# Anthropic API (PM + Delivery agents)
ANTHROPIC_API_KEY="sk-ant-..."

# Ollama (local code generation)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL_DEV="qwen2.5-coder:32b"
OLLAMA_MODEL_FIX="qwen2.5-coder:14b"

# Server
PORT=5680
FRONTEND_URL="http://localhost:5679"

# Generated Projects
OUTPUT_DIR="../../generated-projects"

# Email (Resend)
RESEND_API_KEY=""

# Payments (Stripe) — opcional
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Storage (Cloudflare R2) — opcional
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Deploy
VERCEL_TOKEN=""
RAILWAY_TOKEN=""
GITHUB_TOKEN=""
